# Salin file ini menjadi .env lalu isi nilainya.
PORT=5000
NODE_ENV=development
JWT_SECRET=ganti-dengan-kunci-rahasia
JWT_EXPIRES_IN=7d
# Alamat MongoDB Atlas (sertakan nama database, mis. /teman_berbagi)
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/teman_berbagi?retryWrites=true&w=majority
